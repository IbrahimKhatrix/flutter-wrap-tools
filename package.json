{
  "name": "flutter-wrap-tools",
  "displayName": "flutter-wrap-tools",
  "description": "flutter-wrap-tools",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flutterWrap.wrapWidget",
        "title": "Wrap with Container"
      },
      {
        "command": "flutterWrap.convertArrowToBlock",
        "title": "Convert to block"
      },
      {
        "command": "flutterWrap.wrapStacked",
        "title": "Wrap with Stacked"
      },
      {
        "command": "flutterWrap.unwrapWidget",
        "title": "Unwrap Widget"
      }
    ],
    "keybindings": [
      {
        "command": "flutterWrap.wrapWidget",
        "key": "alt+c",
        "when": "editorTextFocus && editorLangId == dart"
      },
      {
        "command": "flutterWrap.convertArrowToBlock",
        "key": "alt+a",
        "when": "editorTextFocus && editorLangId == dart"
      },
      {
        "command": "flutterWrap.wrapStacked",
        "key": "alt+z",
        "when": "editorTextFocus && editorLangId == dart"
      },
      {
        "command": "flutterWrap.unwrapWidget",
        "key": "alt+x",
        "when": "editorTextFocus && editorLangId == dart"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}